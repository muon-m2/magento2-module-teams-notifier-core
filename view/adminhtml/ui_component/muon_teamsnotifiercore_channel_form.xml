<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                muon_teamsnotifiercore_channel_form.muon_teamsnotifiercore_channel_form_data_source
            </item>
        </item>
        <item name="label" xsi:type="string" translate="true">Channel Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <buttons>
            <button name="back">
                <url path="*/*/"/>
                <class>back</class>
                <label translate="true">Back</label>
            </button>
            <button name="save">
                <url path="*/*/save"/>
                <class>save primary</class>
                <label translate="true">Save Channel</label>
            </button>
        </buttons>
        <namespace>muon_teamsnotifiercore_channel_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>muon_teamsnotifiercore_channel_form.muon_teamsnotifiercore_channel_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="muon_teamsnotifiercore_channel_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="muon_teamsnotifiercore/channel/save"/>
        </settings>
        <dataProvider class="Muon\TeamsNotifierCore\Model\Channel\DataProvider"
                      name="muon_teamsnotifiercore_channel_form_data_source">
            <settings>
                <requestFieldName>channel_id</requestFieldName>
                <primaryFieldName>channel_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Channel Details</label>
        </settings>

        <field name="channel_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>channel_id</dataScope>
            </settings>
        </field>

        <field name="is_active" sortOrder="10" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>

        <field name="name" sortOrder="20" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-identifier" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Name (Slug)</label>
                <notice translate="true">Slug for send() calls, e.g. "ops-alerts". Lowercase, digits, hyphens.</notice>
                <dataScope>name</dataScope>
            </settings>
        </field>

        <field name="label" sortOrder="30" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Label</label>
                <notice translate="true">Human-readable display name shown in the admin grid.</notice>
                <dataScope>label</dataScope>
            </settings>
        </field>

        <field name="webhook_url" sortOrder="40" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Webhook URL</label>
                <notice translate="true">Workflows webhook URL. Leave blank when editing to keep existing.</notice>
                <dataScope>webhook_url</dataScope>
            </settings>
        </field>

        <field name="trigger_secret" sortOrder="50" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Trigger Secret</label>
                <notice translate="true">Optional TriggerSecret. Leave blank when editing to keep existing.</notice>
                <dataScope>trigger_secret</dataScope>
            </settings>
        </field>

        <field name="template_id" sortOrder="60" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Adaptive Card Template</label>
                <notice translate="true">
                    Template applied to all notifications sent to this channel.
                    None uses the caller-supplied card body.
                </notice>
                <dataScope>template_id</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Muon\TeamsNotifierCore\Model\Config\Source\TemplateOptions"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

</form>
