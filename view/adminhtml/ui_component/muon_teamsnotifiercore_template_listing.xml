<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                muon_teamsnotifiercore_template_listing.muon_teamsnotifiercore_template_listing_data_source
            </item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Template</label>
            </button>
        </buttons>
        <spinner>muon_teamsnotifiercore_template_columns</spinner>
        <deps>
            <dep>muon_teamsnotifiercore_template_listing.muon_teamsnotifiercore_template_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="muon_teamsnotifiercore_template_listing_data_source"
        component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">template_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Muon_TeamsNotifierCore::template</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
            name="muon_teamsnotifiercore_template_listing_data_source">
            <settings>
                <requestFieldName>template_id</requestFieldName>
                <primaryFieldName>template_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="muon_teamsnotifiercore_template_columns">
        <column name="template_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Name (Slug)</label>
            </settings>
        </column>
        <column name="label">
            <settings>
                <filter>text</filter>
                <label translate="true">Label</label>
            </settings>
        </column>
        <column name="updated_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Updated</label>
            </settings>
        </column>
        <actionsColumn name="actions"
            class="Muon\TeamsNotifierCore\Ui\Component\Listing\Column\TemplateActions">
            <settings>
                <indexField>template_id</indexField>
                <label translate="true">Actions</label>
            </settings>
        </actionsColumn>
    </columns>

</listing>
