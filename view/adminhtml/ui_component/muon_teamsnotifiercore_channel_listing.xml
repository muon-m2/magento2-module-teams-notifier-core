<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                muon_teamsnotifiercore_channel_listing.muon_teamsnotifiercore_channel_listing_data_source
            </item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Channel</label>
            </button>
        </buttons>
        <spinner>muon_teamsnotifiercore_channel_columns</spinner>
        <deps>
            <dep>muon_teamsnotifiercore_channel_listing.muon_teamsnotifiercore_channel_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="muon_teamsnotifiercore_channel_listing_data_source"
        component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">channel_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Muon_TeamsNotifierCore::channel</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
            name="muon_teamsnotifiercore_channel_listing_data_source">
            <settings>
                <requestFieldName>channel_id</requestFieldName>
                <primaryFieldName>channel_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected channels?</message>
                        <title translate="true">Delete Channels</title>
                    </confirm>
                    <url path="muon_teamsnotifiercore/channel/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="muon_teamsnotifiercore_channel_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>channel_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="channel_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Name (Slug)</label>
            </settings>
        </column>

        <column name="label">
            <settings>
                <filter>text</filter>
                <label translate="true">Label</label>
            </settings>
        </column>

        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Active</label>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
            component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created</label>
            </settings>
        </column>

        <actionsColumn name="actions"
            class="Muon\TeamsNotifierCore\Ui\Component\Listing\Column\ChannelActions">
            <settings>
                <indexField>channel_id</indexField>
            </settings>
        </actionsColumn>
    </columns>

</listing>
