<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="muon_teamsnotifiercore_template" resource="default" engine="innodb"
        comment="Muon Teams Notifier — Reusable Adaptive Card Templates">

        <column xsi:type="int" name="template_id" unsigned="true" nullable="false" identity="true"
            comment="Template ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="64"
            comment="Unique template name slug used in code (e.g. order-alert)"/>
        <column xsi:type="varchar" name="label" nullable="false" length="255"
            comment="Human-readable label shown in the admin grid"/>
        <column xsi:type="mediumtext" name="template_json" nullable="false"
            comment="Full Adaptive Card JSON; may contain dollar-sign-brace placeholder expressions"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false"
            default="CURRENT_TIMESTAMP" comment="Creation timestamp (UTC)"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false"
            default="CURRENT_TIMESTAMP" comment="Last update timestamp (UTC)"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="template_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="MUON_TEAMSNOTIFIERCORE_TEMPLATE_NAME">
            <column name="name"/>
        </constraint>

    </table>

    <table name="muon_teamsnotifiercore_channel" resource="default" engine="innodb"
        comment="Muon Teams Notifier — Incoming Webhook Channels">

        <column xsi:type="int" name="channel_id" unsigned="true" nullable="false" identity="true"
            comment="Channel ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="64"
            comment="Unique channel name slug used in code (e.g. ops-alerts)"/>
        <column xsi:type="varchar" name="label" nullable="false" length="255"
            comment="Human-readable label shown in the admin grid"/>
        <column xsi:type="text" name="webhook_url" nullable="false"
            comment="Incoming Webhook URL (stored encrypted)"/>
        <column xsi:type="text" name="trigger_secret" nullable="true"
            comment="Optional TriggerSecret header value for Power Automate authentication (stored encrypted)"/>
        <column xsi:type="smallint" name="is_active" nullable="false" default="1"
            comment="0 = disabled, 1 = active"/>
        <column xsi:type="int" name="template_id" unsigned="true" nullable="true"
            comment="FK to muon_teamsnotifiercore_template; null means use caller-supplied card body"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false"
            default="CURRENT_TIMESTAMP" comment="Creation timestamp (UTC)"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false"
            default="CURRENT_TIMESTAMP" comment="Last update timestamp (UTC)"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="channel_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="MUON_TEAMSNOTIFIERCORE_CHANNEL_NAME">
            <column name="name"/>
        </constraint>

        <constraint xsi:type="foreign"
            referenceId="MUON_TEAMSNOTIFIERCORE_CHANNEL_TEMPLATE_ID"
            table="muon_teamsnotifiercore_channel" column="template_id"
            referenceTable="muon_teamsnotifiercore_template" referenceColumn="template_id"
            onDelete="SET NULL"/>

    </table>

</schema>
